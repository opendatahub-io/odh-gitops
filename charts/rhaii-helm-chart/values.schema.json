{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "enabled": {
      "type": "boolean",
      "description": "Enable/disable all resource creation",
      "default": true
    },
    "installCRDs": {
      "type": "boolean",
      "description": "Install CRDs or not using the chart",
      "default": true
    },
    "labels": {
      "type": "object",
      "description": "Common labels applied to all resources",
      "additionalProperties": {
        "type": "string"
      }
    },
    "rhaiiOperator": {
      "type": "object",
      "description": "RHAI Operator configuration",
      "properties": {
        "namespace": {
          "type": "string",
          "description": "Operator namespace",
          "default": "redhat-ods-operator"
        },
        "image": {
          "type": "string",
          "description": "Manager container image"
        }
      }
    },
    "azure": {
      "type": "object",
      "description": "Azure cloud configuration",
      "properties": {
        "enabled": {
          "type": "boolean",
          "description": "Enable Azure cloud manager resources",
          "default": false
        },
        "cloudManager": {
          "type": "object",
          "description": "Azure Cloud Manager configuration",
          "properties": {
            "namespace": {
              "type": "string",
              "description": "Cloud Manager operator namespace",
              "default": "opendatahub-operator-system"
            },
            "image": {
              "type": "string",
              "description": "Cloud Manager container image"
            }
          }
        },
        "kubernetesEngine": {
          "type": "object",
          "description": "AzureKubernetesEngine CR configuration",
          "properties": {
            "dependencies": {
              "type": "object",
              "description": "Dependency configurations",
              "properties": {
                "certManager": {
                  "type": "object",
                  "properties": {
                    "managementPolicy": {
                      "type": "string",
                      "enum": ["Managed", "Unmanaged"],
                      "default": "Managed"
                    }
                  }
                },
                "gatewayAPI": {
                  "type": "object",
                  "properties": {
                    "managementPolicy": {
                      "type": "string",
                      "enum": ["Managed", "Unmanaged"],
                      "default": "Managed"
                    }
                  }
                },
                "lws": {
                  "type": "object",
                  "properties": {
                    "managementPolicy": {
                      "type": "string",
                      "enum": ["Managed", "Unmanaged"],
                      "default": "Managed"
                    }
                  }
                },
                "sailOperator": {
                  "type": "object",
                  "properties": {
                    "managementPolicy": {
                      "type": "string",
                      "enum": ["Managed", "Unmanaged"],
                      "default": "Managed"
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "coreweave": {
      "type": "object",
      "description": "CoreWeave cloud configuration",
      "properties": {
        "enabled": {
          "type": "boolean",
          "description": "Enable CoreWeave cloud manager resources",
          "default": false
        },
        "cloudManager": {
          "type": "object",
          "description": "CoreWeave Cloud Manager configuration",
          "properties": {
            "namespace": {
              "type": "string",
              "description": "Cloud Manager operator namespace",
              "default": "opendatahub-operator-system"
            },
            "image": {
              "type": "string",
              "description": "Cloud Manager container image"
            }
          }
        },
        "kubernetesEngine": {
          "type": "object",
          "description": "CoreWeaveKubernetesEngine CR configuration",
          "properties": {
            "dependencies": {
              "type": "object",
              "description": "Dependency configurations",
              "properties": {
                "certManager": {
                  "type": "object",
                  "properties": {
                    "managementPolicy": {
                      "type": "string",
                      "enum": ["Managed", "Unmanaged"],
                      "default": "Managed"
                    }
                  }
                },
                "gatewayAPI": {
                  "type": "object",
                  "properties": {
                    "managementPolicy": {
                      "type": "string",
                      "enum": ["Managed", "Unmanaged"],
                      "default": "Managed"
                    }
                  }
                },
                "lws": {
                  "type": "object",
                  "properties": {
                    "managementPolicy": {
                      "type": "string",
                      "enum": ["Managed", "Unmanaged"],
                      "default": "Managed"
                    }
                  }
                },
                "sailOperator": {
                  "type": "object",
                  "properties": {
                    "managementPolicy": {
                      "type": "string",
                      "enum": ["Managed", "Unmanaged"],
                      "default": "Managed"
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "components": {
      "type": "object",
      "description": "Component CR configurations",
      "properties": {
        "kserve": {
          "type": "object",
          "description": "Kserve component CR configuration",
          "properties": {
            "spec": {
              "type": "object",
              "description": "Kserve CR spec fields",
              "properties": {
                "modelsAsService": {
                  "type": "object",
                  "properties": {
                    "managementState": {
                      "type": "string",
                      "enum": ["Managed", "Removed"]
                    }
                  }
                },
                "nim": {
                  "type": "object",
                  "properties": {
                    "managementState": {
                      "type": "string",
                      "enum": ["Managed", "Removed"]
                    }
                  }
                },
                "rawDeploymentServiceConfig": {
                  "type": "string",
                  "enum": ["Headless", "Headed"]
                }
              }
            }
          }
        }
      }
    },
    "imagePullSecrets": {
      "type": "array",
      "description": "Image pull secrets for private registries (list of secret names)",
      "items": {
        "type": "string"
      }
    }
  }
}
